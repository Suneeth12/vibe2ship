# ==============================================================================
# Vibe2Ship - Server Environment Configuration Template (.env.example)
# Copy this file to '.env' and fill in the values.
# ==============================================================================

# Server Port
PORT=5000

# Environment Mode (development / production / test)
NODE_ENV=development

# Allowed CORS Origins (comma-separated strings)
ALLOWED_ORIGINS=http://localhost:5173

# Gemini API Key (auth key from Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here

# Firebase Admin Service Account Key
# Supports:
# 1. 'ADC' - Application Default Credentials
# 2. File path (e.g. 'D:\PROJECTS\HACKATONS\Vibe2Ship\env\local-sa.json')
# 3. Raw stringified JSON (e.g. '{"type": "service_account", ...}')
FIREBASE_SERVICE_ACCOUNT="your_firebase_service_account_json_or_path_here"

# Firebase Storage Bucket (e.g. 'project-id.appspot.com')
# Optional; if omitted, parsed from the service account's project_id
FIREBASE_STORAGE_BUCKET=

# Google Maps Server API Key (IP restricted)
GOOGLE_MAPS_SERVER_KEY=your_google_maps_server_key_here

# Sentry DSN (optional, for error reporting)
SENTRY_DSN=
