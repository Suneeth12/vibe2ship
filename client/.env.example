# ==============================================================================
# Vibe2Ship - Client Environment Configuration Template (.env.example)
# Copy this file to '.env' and fill in the values.
# ==============================================================================

# Backend API Endpoint URL
VITE_API_URL=http://localhost:5000/api

# Google Maps Client-Side Javascript API Key (HTTP referrer restricted)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_client_key_here

# Firebase Client Configuration overrides (Optional)
# If omitted, default fallbacks are used in dev.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
